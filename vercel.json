{
  "version": 2,
  "functions": {
    "api/*.js": {
      "includeFiles": "api/data.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1.js"
    },
    {
      "source": "/((?!assets/|static/|favicon.ico|vite.svg).*)",
      "destination": "/index.html"
    }
  ]
}
